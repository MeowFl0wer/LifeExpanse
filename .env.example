# Copy to .env and fill in before `docker compose up -d`.

# Session signing, and the key that encrypts secrets at rest (TOTP seeds) and
# keys the verification-code hashes. Generate with: openssl rand -hex 32
#
# WARNING: changing this after go-live invalidates every stored TOTP secret and
# every outstanding verification code. Back it up with the database.
LIFE_SECRET_KEY=

# The site owner's own account — a normal user with a content space.
LIFE_SITE_OWNER=euan

# The administrative account. It owns no content: it manages accounts and site
# settings only, so a compromised admin login does not also expose the diary.
LIFE_ADMIN_USERNAME=AdminEuan
# Password for the admin on first start. Leave empty and one is generated and
# printed to the log exactly once — an unset value must never mean a weak admin.
LIFE_ADMIN_BOOTSTRAP_PASSWORD=

# closed | invite | open. An admin can change this at runtime; this is only
# the value used before one has been set.
LIFE_REGISTRATION_MODE=closed

# ---- Uploads ----
# Bytes live on disk, not in the database. Point this at a mounted volume so
# uploads outlive the container (docker-compose already mounts /data).
LIFE_MEDIA_ROOT=/data/media
LIFE_MAX_IMAGE_BYTES=10485760
LIFE_MAX_VIDEO_BYTES=209715200
# Per-user total. 0 means unlimited.
LIFE_STORAGE_QUOTA_BYTES=2147483648

# ---- Email ----
# console prints messages to the log, which is enough to run the whole
# verification flow without a provider. Switch to resend when ready.
LIFE_EMAIL_BACKEND=console
LIFE_RESEND_API_KEY=
LIFE_EMAIL_FROM=LifeExpanse <noreply@example.com>

# Verification codes: short-lived, single-use, guess-capped and rate limited.
LIFE_VERIFICATION_CODE_TTL_MINUTES=10
LIFE_VERIFICATION_MAX_ATTEMPTS=5
LIFE_VERIFICATION_RATE_LIMIT=5
LIFE_VERIFICATION_RATE_WINDOW_MINUTES=60

# Public origin of the site, for CORS.
LIFE_CORS_ORIGINS=https://life.555978.xyz

# Host port the site is served on.
LIFE_PORT=8080
